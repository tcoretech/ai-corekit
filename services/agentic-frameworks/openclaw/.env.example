# OpenClaw Configuration

# Secure token for gateway WebSocket/API access (auto-generated)
OPENCLAW_GATEWAY_TOKEN=

# Separate token for webhook endpoints (auto-generated if not set)
# IMPORTANT: Use a different token than OPENCLAW_GATEWAY_TOKEN for security
OPENCLAW_HOOKS_TOKEN=

# Port for the gateway
OPENCLAW_GATEWAY_PORT=18789

# Port for the bridge
OPENCLAW_BRIDGE_PORT=18790

# Bind address (lan = accessible on network, local = localhost only)
OPENCLAW_GATEWAY_BIND=lan

# API Keys - inherited from config/.env.global if not set here
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Keys for Claude AI integration (Optional - for Claude Web provider)
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=

# Twilio (Optional - not recommended for WhatsApp, use Web channel instead)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
